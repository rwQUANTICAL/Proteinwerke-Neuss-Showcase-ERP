{
  "css.lint.unknownAtRules": "ignore",
  "cSpell.words": [
    "Apikey",
    "Quantime"
  ],
  "terminal.integrated.profiles.windows": {
    "Dev Server": {
      "source": "PowerShell",
      "icon": "server-process",
      "color": "terminal.ansiBlue",
      "path": "powershell.exe",
      "args": ["-NoExit", "-Command", "cd showcase-erp; npm run dev"],
      "cwd": "${workspaceFolder}",
      "overrideName": true
    },
    "Prisma Studio": {
      "source": "PowerShell",
      "icon": "database",
      "color": "terminal.ansiRed",
      "path": "powershell.exe",
      "args": ["-NoExit", "-Command", "cd showcase-erp; npx --yes prisma studio"],
      "cwd": "${workspaceFolder}",
      "overrideName": true
    },
  },
  "chat.agentSkillsLocations": {
    ".github/skills": true,
    ".agents/skills": true,
    ".claude/skills": true,
    "~/.copilot/skills": true,
    "~/.agents/skills": true,
    "~/.claude/skills": true,
    "~/.vscode/extensions/synapsevscode.synapse-1.22.0/copilot/skills": true
  }
}
