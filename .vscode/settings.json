{
  "css.lint.unknownAtRules": "ignore",
  "cSpell.words": [
    "Apikey",
    "Quantime"
  ],
  "terminal.integrated.profiles.windows": {
    "Dev Server": {
      "source": "PowerShell",
      "icon": "server-process",
      "color": "terminal.ansiBlue",
      "path": "powershell.exe",
      "args": ["-NoExit", "-Command", "cd showcase-er; npm run dev"],
      "cwd": "${workspaceFolder}",
      "overrideName": true
    },
    "Prisma Studio": {
      "source": "PowerShell",
      "icon": "database",
      "color": "terminal.ansiRed",
      "path": "powershell.exe",
      "args": ["-NoExit", "-Command", "cd showcase-er; npx --yes prisma studio"],
      "cwd": "${workspaceFolder}",
      "overrideName": true
    },
  }
}
